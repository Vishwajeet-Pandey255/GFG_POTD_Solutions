class Solution {
    public int longestCycle(int V, int[][] edges) {
        // Build graph: each node has at most one outgoing edge
        int[] graph = new int[V];
        for (int i = 0; i < V; i++) {
            graph[i] = -1; // default no outgoing edge
        }
        
        for (int[] e : edges) {
            graph[e[0]] = e[1];
        }
        
        boolean[] visited = new boolean[V];
        int maxCycle = -1;
        
        for (int i = 0; i < V; i++) {
            if (visited[i]) continue;
            
            int curr = i;
            int step = 0;
            
            // Map to store node -> step index
            java.util.HashMap<Integer, Integer> map = new java.util.HashMap<>();
            
            while (curr != -1 && !visited[curr]) {
                visited[curr] = true;
                map.put(curr, step++);
                
                curr = graph[curr];
                
                // Cycle detected
                if (curr != -1 && map.containsKey(curr)) {
                    int cycleLength = step - map.get(curr);
                    maxCycle = Math.max(maxCycle, cycleLength);
                    break;
                }
            }
        }
        
        return maxCycle;
    }
}

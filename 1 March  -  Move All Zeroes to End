class Solution {
    void pushZerosToEnd(int[] arr) {
        int n = arr.length;
        int index = 0;  // position to place next non-zero element
        
        // Move all non-zero elements to the front
        for (int i = 0; i < n; i++) {
            if (arr[i] != 0) {
                arr[index] = arr[i];
                index++;
            }
        }
        
        // Fill remaining positions with zeros
        while (index < n) {
            arr[index] = 0;
            index++;
        }
    }
}

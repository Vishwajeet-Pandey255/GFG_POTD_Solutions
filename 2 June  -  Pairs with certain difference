class Solution {
    public int sumDiffPairs(int[] arr, int k) {
        Arrays.sort(arr);
        
        int sum = 0;
        int n = arr.length;
        
        for (int i = n - 1; i > 0; ) {
            if (arr[i] - arr[i - 1] < k) {
                sum += arr[i] + arr[i - 1];
                i -= 2; // use both elements, pairs must be disjoint
            } else {
                i--;
            }
        }
        
        return sum;
    }
}

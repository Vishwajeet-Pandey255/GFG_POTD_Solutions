/*
Definition for Node
class Node {
    int data;
    Node left;
    Node right;

    Node(int x) {
        data = x;
        left = right = null;
    }
}
*/

class Solution {
    
    // Function to check if two trees are identical
    boolean isIdentical(Node a, Node b) {
        
        // If both are null
        if (a == null && b == null)
            return true;
        
        // If one is null and other is not
        if (a == null || b == null)
            return false;
        
        // Check current node data and subtrees
        return (a.data == b.data) &&
               isIdentical(a.left, b.left) &&
               isIdentical(a.right, b.right);
    }
    
    public boolean isSubTree(Node root1, Node root2) {
        
        // Empty tree is always subtree
        if (root2 == null)
            return true;
        
        // If main tree becomes null
        if (root1 == null)
            return false;
        
        // Check if trees are identical at current node
        if (isIdentical(root1, root2))
            return true;
        
        // Check in left and right subtree
        return isSubTree(root1.left, root2) ||
               isSubTree(root1.right, root2);
    }
}

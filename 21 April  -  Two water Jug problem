class Solution {

    // Function to calculate GCD
    private int gcd(int a, int b) {
        if (b == 0) return a;
        return gcd(b, a % b);
    }

    // Function to simulate pouring process
    private int pour(int fromCap, int toCap, int d) {
        int from = fromCap; // fill from jug
        int to = 0;         // to jug initially empty

        int step = 1; // first step: fill from jug

        while (from != d && to != d) {
            // pour water
            int temp = Math.min(from, toCap - to);
            to += temp;
            from -= temp;
            step++;

            // check if we got result
            if (from == d || to == d)
                break;

            // if from jug becomes empty
            if (from == 0) {
                from = fromCap;
                step++;
            }

            // if to jug becomes full
            if (to == toCap) {
                to = 0;
                step++;
            }
        }
        return step;
    }

    public int minSteps(int m, int n, int d) {
        // Base conditions
        if (d > Math.max(m, n)) return -1;

        if (d % gcd(m, n) != 0) return -1;

        // Try both ways and return minimum
        return Math.min(pour(m, n, d), pour(n, m, d));
    }
}

class Solution {
    public int maxSum(int n) {
        // If breaking gives smaller value, keep n itself
        return solve(n);
    }
    
    private int solve(int n) {
        if (n == 0) {
            return 0;
        }
        
        int breakSum = solve(n / 2) + solve(n / 3) + solve(n / 4);
        
        return Math.max(n, breakSum);
    }
}

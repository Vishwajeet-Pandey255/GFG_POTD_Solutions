class Solution {
    public int maxProfit(int arr[], int k) {
        int n = arr.length;
        
        int hold = -arr[0];  // Buying first stock
        int cash = 0;        // No stock in hand
        
        for (int i = 1; i < n; i++) {
            // Update cash (sell)
            cash = Math.max(cash, hold + arr[i] - k);
            
            // Update hold (buy)
            hold = Math.max(hold, cash - arr[i]);
        }
        
        return cash;
    }
}

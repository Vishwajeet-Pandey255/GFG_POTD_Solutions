class Solution {
    public int minSwaps(int[] arr) {
        int ones = 0;
        
        // Count total number of 1s
        for (int num : arr) {
            if (num == 1) {
                ones++;
            }
        }
        
        // If no 1s are present
        if (ones == 0) {
            return -1;
        }
        
        int zerosInWindow = 0;
        
        // Count zeros in the first window of size = ones
        for (int i = 0; i < ones; i++) {
            if (arr[i] == 0) {
                zerosInWindow++;
            }
        }
        
        int minSwaps = zerosInWindow;
        
        // Sliding window
        for (int i = ones; i < arr.length; i++) {
            
            // Remove outgoing element
            if (arr[i - ones] == 0) {
                zerosInWindow--;
            }
            
            // Add incoming element
            if (arr[i] == 0) {
                zerosInWindow++;
            }
            
            minSwaps = Math.min(minSwaps, zerosInWindow);
        }
        
        return minSwaps;
    }
}

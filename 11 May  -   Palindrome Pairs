class Solution {
    
    private boolean isPalindrome(String s, int left, int right) {
        while (left < right) {
            if (s.charAt(left++) != s.charAt(right--))
                return false;
        }
        return true;
    }

    public boolean palindromePair(String[] arr) {

        int n = arr.length;

        // Store reversed strings
        HashMap<String, Integer> map = new HashMap<>();

        for (int i = 0; i < n; i++) {
            String rev = new StringBuilder(arr[i]).reverse().toString();
            map.put(rev, i);
        }

        for (int i = 0; i < n; i++) {

            String s = arr[i];
            int len = s.length();

            for (int cut = 0; cut <= len; cut++) {

                String left = s.substring(0, cut);
                String right = s.substring(cut);

                // Case 1:
                // left part palindrome -> need reverse(right)
                if (isPalindrome(left, 0, left.length() - 1)) {

                    Integer idx = map.get(right);

                    if (idx != null && idx != i) {
                        return true;
                    }
                }

                // Case 2:
                // right part palindrome -> need reverse(left)
                // cut != len avoids duplicate checking
                if (cut != len &&
                    isPalindrome(right, 0, right.length() - 1)) {

                    Integer idx = map.get(left);

                    if (idx != null && idx != i) {
                        return true;
                    }
                }
            }
        }

        return false;
    }
}

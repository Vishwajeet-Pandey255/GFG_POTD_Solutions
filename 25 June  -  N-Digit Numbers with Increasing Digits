class Solution {
    public static ArrayList<Integer> increasingNumbers(int n) {
        ArrayList<Integer> result = new ArrayList<>();
        
        if (n > 10) return result; // Not possible
        
        if (n == 1) {
            for (int i = 0; i <= 9; i++) {
                result.add(i);
            }
            return result;
        }
        
        generate(n, 1, "", result);
        return result;
    }
    
    private static void generate(int n, int start, String curr, ArrayList<Integer> result) {
        if (curr.length() == n) {
            result.add(Integer.parseInt(curr));
            return;
        }
        
        for (int digit = start; digit <= 9; digit++) {
            generate(n, digit + 1, curr + digit, result);
        }
    }
}

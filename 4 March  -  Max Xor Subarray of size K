class Solution {
    public int maxSubarrayXOR(int[] arr, int k) {
        int n = arr.length;
        
        // Step 1: Calculate XOR of first window of size k
        int currentXor = 0;
        for (int i = 0; i < k; i++) {
            currentXor ^= arr[i];
        }
        
        int maxXor = currentXor;
        
        // Step 2: Slide the window
        for (int i = k; i < n; i++) {
            // Remove element going out of window
            currentXor ^= arr[i - k];
            
            // Add new element
            currentXor ^= arr[i];
            
            // Update maximum
            maxXor = Math.max(maxXor, currentXor);
        }
        
        return maxXor;
    }
}

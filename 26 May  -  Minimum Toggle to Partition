class Solution {
    int minToggle(int[] arr) {
        int n = arr.length;

        // prefixOne[i] = number of 1s from 0 to i-1
        int[] prefixOne = new int[n + 1];

        for (int i = 0; i < n; i++) {
            prefixOne[i + 1] = prefixOne[i] + (arr[i] == 1 ? 1 : 0);
        }

        int totalZero = 0;
        for (int x : arr) {
            if (x == 0) totalZero++;
        }

        int ans = Integer.MAX_VALUE;

        // Partition at every position
        // Left side should be all 0s
        // Right side should be all 1s
        for (int i = 0; i <= n; i++) {

            // 1s on left need to change to 0
            int leftToggle = prefixOne[i];

            // 0s on right need to change to 1
            int rightZero = totalZero - (i - prefixOne[i]);

            ans = Math.min(ans, leftToggle + rightZero);
        }

        return ans;
    }
}
